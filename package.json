{
  "name": "geoexpert",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-data": "tsx scripts/fetch-countries.ts",
    "device": "source .env.local && npm run build && npx cap sync && xcodebuild -project ios/App/App.xcodeproj -scheme App -destination \"id=$IOS_DEVICE_UDID\" -derivedDataPath ios/DerivedData build && xcrun devicectl device install app --device $IOS_DEVICE_ID ios/DerivedData/Build/Products/Debug-iphoneos/App.app && xcrun devicectl device launch app --terminate-existing --device $IOS_DEVICE_ID $IOS_BUNDLE_ID"
  },
  "dependencies": {
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "d3-geo": "^3.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
